{
  "rewrites": [
    {
      "source": "/api/backProyectoFinal/public/api/:path*",
      "destination": "https://books4u-backend.onrender.com/api/:path*"
    },
    {
      "source": "/api/backProyectoFinal/public/img/:path*",
      "destination": "https://books4u-backend.onrender.com/img/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/es/assets/:path*"
    },
    {
      "source": "/favicon.ico",
      "destination": "/es/favicon.ico"
    },
    {
      "source": "/en/:path*",
      "destination": "/en/index.html"
    },
    {
      "source": "/es/:path*",
      "destination": "/es/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "accept-language",
          "value": "(^en.*)"
        }
      ],
      "permanent": false,
      "destination": "/en/"
    },
    {
      "source": "/",
      "permanent": false,
      "destination": "/es/"
    }
  ]
}

